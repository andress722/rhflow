generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  HR
  MANAGER
  VIEWER
}

enum PilotStatus {
  NOT_STARTED
  ACTIVE
  PROPOSAL_SENT
  WON
  LOST
}

enum WorkModel {
  PRESENTIAL
  REMOTE
  HYBRID
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum OccurrenceType {
  MISSED_CLOCK_IN
  MISSED_CLOCK_OUT
  LATE_ARRIVAL
  EARLY_LEAVE
  ABSENCE
  TEMPORARY_ABSENCE
  MEDICAL_CERTIFICATE
  REMOTE_CHECKIN_MISSED
  REMOTE_CHECKOUT_MISSED
  REMOTE_TECHNICAL_ISSUE
  REMOTE_CHECKIN_NOT_RESPONDED
}

enum OccurrenceStatus {
  OPEN
  WAITING_EMPLOYEE
  WAITING_MANAGER
  WAITING_HR
  RESOLVED
  REJECTED
  CANCELLED
}

enum OccurrenceSource {
  SYSTEM
  WHATSAPP
  MANUAL
  IMPORT
  AUTOMATION
}

enum MedicalCertificateStatus {
  RECEIVED
  UNDER_REVIEW
  APPROVED
  REJECTED
  RESUBMISSION_REQUESTED
}

model Company {
  id        String   @id @default(uuid())
  name      String
  legalName String?
  cnpj      String?
  timezone  String   @default("America/Sao_Paulo")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users               User[]
  employees           Employee[]
  workSchedules       WorkSchedule[]
  occurrences         Occurrence[]
  occurrenceEvents    OccurrenceEvent[]
  medicalCertificates MedicalCertificate[]
  absenceRecords      AbsenceRecord[]
  remoteCheckins      RemoteCheckin[]
  auditLogs           AuditLog[]
  settings            CompanySettings?
  subscription        CompanySubscription?
  usageCounters       UsageCounter[]
  whatsappChannel     WhatsAppChannel?
  whatsappMessageLogs WhatsAppMessageLog[]
  invites             UserInvite[]
  pilotFeedbacks      PilotFeedback[]
  pilotBacklogItems   PilotBacklogItem[]
  notifications       InAppNotification[]
  notificationPreferences    NotificationPreference[]
  escalationRules            NotificationEscalationRule[]
  digests                    NotificationDigest[]
  timesheetSignatures        TimesheetSignature[]
  pulseSurveys               PulseSurvey[]
  apiKeys                    ApiKey[]
  webhookSubscriptions       WebhookSubscription[]
  biometricConfiguration     BiometricProcessingConfiguration?
  leaveRequests              LeaveRequest[]
  calendarIntegration        CalendarIntegration?
  notificationPolicies             NotificationPolicy[]
  notificationWorkflowInstances     NotificationWorkflowInstance[]
  notificationDeliveryAttempts      NotificationDeliveryAttempt[]
  notificationQuietHoursConfig      NotificationQuietHours?
  notificationMessageTemplates      NotificationMessageTemplate[]
  importJobs                         ImportJob[]
  importMappingTemplates             ImportMappingTemplate[]

  pilotStatus     PilotStatus @default(NOT_STARTED)
  pilotStartedAt  DateTime?
  pilotEndsAt     DateTime?
  proposalSentAt  DateTime?
  convertedAt     DateTime?
  pilotLostReason String?
  commercialNotes String?
}

model User {
  id           String   @id @default(uuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  name         String
  email        String
  passwordHash String
  role         UserRole
  isActive     Boolean  @default(true)
  mustChangePassword Boolean @default(false)
  lastLoginAt  DateTime?
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  managedEmployees     Employee[]           @relation("ManagerToEmployee")
  occurrences          Occurrence[]         @relation("ManagerToOccurrence")
  resolvedOccurrences  Occurrence[]         @relation("ResolvedByToOccurrence")
  reviewedCertificates MedicalCertificate[] @relation("ReviewedByToCertificate")
  createdAbsenceRecords AbsenceRecord[]     @relation("CreatedByUserToAbsence")
  assignedFeedbacks    PilotFeedback[]      @relation("AssignedFeedbacks")
  auditLogs            AuditLog[]
  timesheetSignatures  TimesheetSignature[]
  passwordResetTokens  PasswordResetToken[]
  createdInvites       UserInvite[]         @relation("CreatedInvites")
  assignedLeads        PilotLead[]          @relation("AssignedToUser")
  leadActivities       LeadActivity[]       @relation("CreatedByUser")
  assignedBacklogItems PilotBacklogItem[]   @relation("AssignedBacklogItems")
  createdArticles      KnowledgeArticle[]   @relation("CreatedArticles")
  updatedArticles      KnowledgeArticle[]   @relation("UpdatedArticles")
  webPushSubscriptions WebPushSubscription[]
  reviewedLeaveRequests LeaveRequest[]       @relation("ReviewedByToLeave")
  actedTransactions    HourBankTransaction[] @relation("ActorToTransaction")
  importJobs           ImportJob[]           @relation("CreatedByToImportJob")
  importMappingTemplates ImportMappingTemplate[] @relation("CreatedByToMappingTemplate")

  @@unique([companyId, email])
}

model Employee {
  id             String         @id @default(uuid())
  companyId      String
  company        Company        @relation(fields: [companyId], references: [id])
  managerUserId  String?
  manager        User?          @relation("ManagerToEmployee", fields: [managerUserId], references: [id])
  fullName       String
  cpf            String
  whatsapp       String
  email          String?
  sector         String?
  jobTitle       String?
  registrationNumber String?        // Optional employee registry / matricula
  workModel      WorkModel      @default(PRESENTIAL)
  workScheduleId String?
  workSchedule   WorkSchedule?  @relation(fields: [workScheduleId], references: [id])
  status         EmployeeStatus @default(ACTIVE)
  inactivationReason String?
  turnoverRiskScore  Int?           @default(15)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  occurrences         Occurrence[]
  medicalCertificates MedicalCertificate[]
  absenceRecords      AbsenceRecord[]
  remoteCheckins      RemoteCheckin[]
  timesheetSignatures TimesheetSignature[]
  pulseResponses      PulseSurveyResponse[]
  hourBankBalance     HourBankBalance?
  hourBankTransactions HourBankTransaction[]
  leaveRequests       LeaveRequest[]

  @@unique([companyId, cpf])
}

model WorkSchedule {
  id                    String   @id @default(uuid())
  companyId             String
  company               Company  @relation(fields: [companyId], references: [id])
  name                  String
  workDays              Json
  expectedClockIn        String
  expectedClockOut       String
  toleranceMinutes       Int      @default(10)
  requireRemoteCheckin   Boolean  @default(false)
  requireRemoteCheckout  Boolean  @default(false)
  latitude              Float?
  longitude             Float?
  radiusMeters          Int?     @default(200)
  scheduleType          String   @default("WEEKLY")
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  employees Employee[]
  remoteCheckins RemoteCheckin[]
}

model Occurrence {
  id               String           @id @default(uuid())
  companyId        String
  company          Company          @relation(fields: [companyId], references: [id])
  employeeId       String
  employee         Employee         @relation(fields: [employeeId], references: [id])
  managerUserId    String?
  manager          User?            @relation("ManagerToOccurrence", fields: [managerUserId], references: [id])
  type             OccurrenceType
  status           OccurrenceStatus @default(OPEN)
  title            String
  description      String?
  occurrenceDate   DateTime
  source           OccurrenceSource @default(SYSTEM)
  severity         String           @default("LOW")
  justificationText          String?
  justificationAttachmentUrl  String?
  isAbonado                  Boolean          @default(false)
  resolvedAt       DateTime?
  resolvedByUserId String?
  resolvedBy       User?            @relation("ResolvedByToOccurrence", fields: [resolvedByUserId], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  events              OccurrenceEvent[]
  medicalCertificates MedicalCertificate[]
  absenceRecords      AbsenceRecord[]
  remoteCheckins      RemoteCheckin[]

  @@index([companyId, status, createdAt])
  @@index([companyId, type, createdAt])
}

model OccurrenceEvent {
  id           String     @id @default(uuid())
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id])
  occurrenceId String
  occurrence   Occurrence @relation(fields: [occurrenceId], references: [id])
  actorType    String
  actorUserId  String?
  eventType    String
  message      String?
  metadata     Json?
  createdAt    DateTime   @default(now())
}

model MedicalCertificate {
  id                String                   @id @default(uuid())
  companyId         String
  company           Company                  @relation(fields: [companyId], references: [id])
  employeeId        String
  employee          Employee                 @relation(fields: [employeeId], references: [id])
  occurrenceId      String?
  occurrence        Occurrence?              @relation(fields: [occurrenceId], references: [id])
  originalFilename  String
  storedFilename    String
  mimeType          String
  fileSize          Int
  storagePath       String
  status            MedicalCertificateStatus @default(RECEIVED)
  certificateDate   DateTime?
  suggestedDays     Int?
  startDate         DateTime?
  endDate           DateTime?
  approvedDays      Int?
  rejectionReason   String?
  notes             String?
  reviewedByUserId  String?
  reviewedBy        User?                    @relation("ReviewedByToCertificate", fields: [reviewedByUserId], references: [id])
  reviewedAt        DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  absenceRecords      AbsenceRecord[]

  @@index([companyId, status, createdAt])
}

enum AbsenceType {
  MEDICAL_LEAVE
  JUSTIFIED_ABSENCE
  UNJUSTIFIED_ABSENCE
  TEMPORARY_ABSENCE
}

enum AbsenceStatus {
  ACTIVE
  ENDED
  CANCELLED
}

model AbsenceRecord {
  id                   String             @id @default(uuid())
  companyId            String
  company              Company            @relation(fields: [companyId], references: [id])
  employeeId           String
  employee             Employee           @relation(fields: [employeeId], references: [id])
  occurrenceId         String?
  occurrence           Occurrence?        @relation(fields: [occurrenceId], references: [id])
  medicalCertificateId String?
  medicalCertificate   MedicalCertificate? @relation(fields: [medicalCertificateId], references: [id])
  leaveRequestId       String?            @unique
  leaveRequest         LeaveRequest?      @relation(fields: [leaveRequestId], references: [id])
  startDate            DateTime
  endDate              DateTime
  days                 Int
  type                 AbsenceType
  status               AbsenceStatus
  externalCalendarEventId String?
  externalCalendarProvider String?
  createdByUserId      String
  createdByUser        User               @relation("CreatedByUserToAbsence", fields: [createdByUserId], references: [id])
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

enum RemoteCheckinStatus {
  PENDING
  CONFIRMED
  LATE
  ABSENCE_REPORTED
  ISSUE_REPORTED
  NOT_RESPONDED
}

model RemoteCheckin {
  id              String              @id @default(uuid())
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id])
  employeeId      String
  employee        Employee            @relation(fields: [employeeId], references: [id])
  workScheduleId  String?
  workSchedule    WorkSchedule?       @relation(fields: [workScheduleId], references: [id])
  occurrenceId    String?
  occurrence      Occurrence?         @relation(fields: [occurrenceId], references: [id])
  checkinDate     DateTime            // Normalized date representing the local date start
  expectedAt      DateTime?
  sentAt          DateTime            @default(now())
  respondedAt     DateTime?
  status          RemoteCheckinStatus @default(PENDING)
  responseOption  String?
  responseText    String?
  source          String              @default("AUTOMATION")
  latitude        Float?
  longitude       Float?
  selfieUrl       String?
  isOutOfBounds   Boolean             @default(false)
  faceMatchScore  Float?
  faceVerificationStatus String?
  clientCapturedAt        DateTime?
  timezone                String?
  deviceIdHash            String?
  offlineEventId          String?             @unique
  offlineSequence         Int?
  previousEventHash       String?
  payloadHash             String?
  integrityVersion        Int                 @default(1)
  syncStatus              String              @default("ONLINE")
  clockDriftSeconds       Int?
  offlineEvidenceStatus   String?
  accuracyMeters          Float?
  geofenceDistanceMeters  Float?
  configuredRadiusMeters  Float?
  geofenceResult          String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([employeeId, checkinDate])
  @@index([companyId, checkinDate])
  @@index([companyId, status, checkinDate])
}

model AuditLog {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([companyId, action])
  @@index([companyId, createdAt])
  @@index([userId])
  @@index([companyId, action, createdAt])
}

model CompanySettings {
  id                          String   @id @default(uuid())
  companyId                   String   @unique
  company                     Company  @relation(fields: [companyId], references: [id])
  defaultCheckinGraceMinutes  Int      @default(30)
  defaultCheckinSendTime      String?
  allowManagerExport          Boolean  @default(true)
  allowViewerReports          Boolean  @default(true)
  enableRemoteCheckin         Boolean  @default(true)
  enableBatchCheckin          Boolean  @default(true)
  enableMedicalCertificates   Boolean  @default(true)
  whatsappCheckinMessage      String?
  whatsappNotRespondedMessage String?
  whatsappManagerAlertMessage String?
  absenteeismLimitRate        Float    @default(2.0)
  enableFacialRecognition     Boolean  @default(false)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
}

enum BillingStatus {
  TRIAL
  ACTIVE
  PAYMENT_PENDING
  OVERDUE
  CANCELED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

model Plan {
  id                 String   @id @default(uuid())
  name               String
  code               String   @unique
  maxEmployees       Int      @default(10)
  maxMonthlyCheckins Int      @default(300)
  maxMonthlyUploads  Int      @default(50)
  maxMonthlyExports  Int      @default(5)
  enableReports      Boolean  @default(true)
  enableBatchCheckin Boolean  @default(false)
  enableMedicalModule Boolean  @default(false)
  enableExports      Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  subscriptions      CompanySubscription[]
}

model CompanySubscription {
  id        String             @id @default(uuid())
  companyId String             @unique
  company   Company            @relation(fields: [companyId], references: [id])
  planId    String
  plan      Plan               @relation(fields: [planId], references: [id])
  status    SubscriptionStatus @default(ACTIVE)
  startedAt DateTime           @default(now())
  endsAt    DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  billingStatus        BillingStatus @default(TRIAL)
  contractedAmountCents Int          @default(0)
  billingCycle         BillingCycle  @default(MONTHLY)
  contractSentAt       DateTime?
  contractSignedAt     DateTime?
  subscriptionStartedAt DateTime?
  nextBillingAt        DateTime?
  canceledAt           DateTime?
  cancellationReason   String?
  financeNotes         String?

  @@index([billingStatus, nextBillingAt])
}

model UsageCounter {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  period    String   // Format YYYY-MM
  key       String   // e.g. "employees_created", "remote_checkins", "medical_uploads", "report_exports"
  value     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, period, key])
  @@index([companyId, period])
}

enum WhatsAppProvider {
  SIMULATED
  META_CLOUD
}

enum WhatsAppChannelStatus {
  DISCONNECTED
  CONNECTED
  ERROR
  SIMULATION
}

enum WhatsAppMessageDirection {
  INBOUND
  OUTBOUND
}

enum WhatsAppMessageStatus {
  SENT
  RECEIVED
  FAILED
  SIMULATED
}

model WhatsAppChannel {
  id             String                @id @default(uuid())
  companyId      String                @unique
  company        Company               @relation(fields: [companyId], references: [id])
  provider       WhatsAppProvider      @default(SIMULATED)
  status         WhatsAppChannelStatus @default(SIMULATION)
  channelKey     String                @unique @default(uuid())
  phoneNumber    String?
  displayName    String?
  webhookSecret  String?
  accessTokenEnc String?
  providerConfig Json                  @default("{}")
  lastInboundAt  DateTime?
  lastOutboundAt DateTime?
  lastError      String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([companyId])
  @@index([channelKey])
}

model WhatsAppMessageLog {
  id        String                   @id @default(uuid())
  companyId String
  company   Company                  @relation(fields: [companyId], references: [id])
  direction WhatsAppMessageDirection
  provider  WhatsAppProvider
  to        String
  from      String
  body      String
  status    WhatsAppMessageStatus
  metadata  Json                     @default("{}")
  createdAt DateTime                 @default(now())

  @@index([companyId, createdAt(sort: Desc)])
  @@index([companyId, direction])
  @@index([companyId, status])
  @@index([companyId, status, createdAt])
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}

model UserInvite {
  id              String    @id @default(uuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email           String
  role            UserRole
  tokenHash       String    @unique
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdByUserId String
  createdByUser   User      @relation("CreatedInvites", fields: [createdByUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())

  @@index([companyId, email])
  @@index([expiresAt])
  @@index([acceptedAt])
}

model OperationalErrorLog {
  id         String   @id @default(uuid())
  companyId  String?
  userId     String?
  requestId  String?
  route      String?
  method     String?
  errorCode  String
  message    String
  statusCode Int?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([requestId])
  @@index([errorCode, createdAt])
  @@index([statusCode, createdAt])
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

enum LeadActivityType {
  NOTE
  STATUS_CHANGED
  CONTACTED
  DEMO_SCHEDULED
  FOLLOW_UP_SCHEDULED
  WON
  LOST
}

model PilotLead {
  id               String         @id @default(uuid())
  name             String
  companyName      String
  role             String?
  email            String
  whatsapp         String?
  employeeCount    Int?
  mainPain         String?
  status           LeadStatus     @default(NEW)
  source           String?
  notes            String?
  ipHash           String?
  userAgent        String?
  metadata         Json?
  assignedToUserId String?
  assignedTo       User?          @relation("AssignedToUser", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  nextFollowUpAt   DateTime?
  lastContactedAt  DateTime?
  demoScheduledAt  DateTime?
  lostReason       String?
  wonAt            DateTime?
  activities       LeadActivity[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([email])
  @@index([assignedToUserId])
  @@index([nextFollowUpAt])
  @@index([demoScheduledAt])
}

model LeadActivity {
  id              String           @id @default(uuid())
  leadId          String
  lead            PilotLead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type            LeadActivityType
  note            String?
  metadata        Json?
  createdByUserId String?
  createdByUser   User?            @relation("CreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now())

  @@index([leadId])
  @@index([createdByUserId])
  @@index([type])
  @@index([createdAt])
}

enum JobRunStatus {
  SUCCESS
  FAILED
  SKIPPED
  RUNNING
}

enum JobTriggerType {
  INTERNAL
  MANUAL
  SYSTEM
}

model JobRun {
  id           String         @id @default(uuid())
  jobKey       String
  status       JobRunStatus
  startedAt    DateTime
  finishedAt   DateTime?
  durationMs   Int?
  triggeredBy  JobTriggerType
  requestId    String?
  summary      Json?
  errorCode    String?
  errorMessage String?
  createdAt    DateTime       @default(now())

  @@index([jobKey])
  @@index([status])
  @@index([startedAt])
  @@index([jobKey, startedAt])
}

enum PilotFeedbackSource {
  WHATSAPP
  CALL
  EMAIL
  MEETING
  INTERNAL
  SYSTEM
}

enum PilotFeedbackCategory {
  BUG
  QUESTION
  USABILITY
  TRAINING
  FEATURE_REQUEST
  INCIDENT
  COMMERCIAL
  OTHER
}

enum PilotFeedbackSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PilotFeedbackStatus {
  OPEN
  IN_REVIEW
  PLANNED
  RESOLVED
  DISMISSED
}

model PilotFeedback {
  id               String                @id @default(uuid())
  companyId        String
  company          Company               @relation(fields: [companyId], references: [id])
  reportedByName   String
  reportedByRole   String?
  source           PilotFeedbackSource
  category         PilotFeedbackCategory
  severity         PilotFeedbackSeverity
  status           PilotFeedbackStatus   @default(OPEN)
  title            String                @db.VarChar(200)
  description      String                @db.VarChar(5000)
  impact           String?               @db.VarChar(2000)
  actionTaken      String?               @db.VarChar(2000)
  relatedRequestId String?
  relatedUrl       String?
  assignedToUserId String?
  assignedTo       User?                 @relation("AssignedFeedbacks", fields: [assignedToUserId], references: [id])
  resolvedAt       DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  backlogItems     PilotBacklogItem[]
  knowledgeArticleId String?
  knowledgeArticle   KnowledgeArticle?    @relation(fields: [knowledgeArticleId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([status])
  @@index([severity])
  @@index([category])
}

enum PilotBacklogType {
  BUGFIX
  IMPROVEMENT
  CONFIGURATION
  TRAINING
  DOCUMENTATION
  FEATURE_REQUEST
}

enum PilotBacklogPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PilotBacklogStatus {
  TRIAGED
  PLANNED
  IN_PROGRESS
  DONE
  CANCELED
}

model PilotBacklogItem {
  id                 String               @id @default(uuid())
  companyId          String
  company            Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  feedbackId         String?
  feedback           PilotFeedback?       @relation(fields: [feedbackId], references: [id], onDelete: SetNull)
  title              String               @db.VarChar(200)
  description        String               @db.VarChar(5000)
  type               PilotBacklogType
  priority           PilotBacklogPriority
  status             PilotBacklogStatus   @default(TRIAGED)
  impact             String?              @db.VarChar(3000)
  rootCause          String?              @db.VarChar(3000)
  plannedAction      String?              @db.VarChar(3000)
  releaseNote        String?              @db.VarChar(3000)
  targetReleaseDate  DateTime?
  completedAt        DateTime?
  assignedToUserId   String?
  assignedTo         User?                @relation("AssignedBacklogItems", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([companyId])
  @@index([status])
  @@index([priority])
}

enum KnowledgeCategory {
  ONBOARDING
  WHATSAPP
  CHECKIN
  OCCURRENCES
  MEDICAL_CERTIFICATES
  REPORTS
  BILLING
  TROUBLESHOOTING
  FAQ
  RELEASE_NOTES
}

enum KnowledgeAudience {
  SUPER_ADMIN
  ADMIN_HR
  MANAGER
  EMPLOYEE
  PUBLIC
}

enum KnowledgeStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model KnowledgeArticle {
  id              String            @id @default(uuid())
  title           String            @db.VarChar(200)
  slug            String            @unique
  category        KnowledgeCategory
  audience        KnowledgeAudience
  status          KnowledgeStatus   @default(DRAFT)
  summary         String            @db.VarChar(500)
  contentMarkdown String            @db.Text
  tags            String[]
  relatedUrl      String?
  createdByUserId String?
  createdByUser   User?             @relation("CreatedArticles", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId String?
  updatedByUser   User?             @relation("UpdatedArticles", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  publishedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  feedbacks       PilotFeedback[]

  @@index([category])
  @@index([audience])
  @@index([status])
}

model UsageTelemetry {
  id              String            @id @default(uuid())
  companyId       String?
  userId          String?
  eventName       String
  category        String
  properties      Json
  createdAt       DateTime          @default(now())

  @@index([companyId])
  @@index([userId])
  @@index([eventName])
  @@index([createdAt])
  @@index([eventName, createdAt])
  @@index([companyId, createdAt])
}
enum NotificationSeverity {
  INFO
  SUCCESS
  WARNING
  CRITICAL
}

enum NotificationStatus {
  UNREAD
  READ
  DISMISSED
  RESOLVED
}

model InAppNotification {
  id          String               @id @default(uuid())
  companyId   String?
  company     Company?             @relation(fields: [companyId], references: [id])
  userId      String?
  role        String?
  type        String
  severity    NotificationSeverity @default(INFO)
  status      NotificationStatus   @default(UNREAD)
  title       String               @db.VarChar(200)
  message     String               @db.VarChar(1000)
  actionUrl   String?
  entityType  String?
  entityId    String?
  dedupeKey   String?              @unique
  metadata    Json?
  readAt      DateTime?
  dismissedAt DateTime?
  resolvedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([companyId, status, createdAt(sort: Desc)])
  @@index([userId, status])
  @@index([role, companyId])
  @@index([severity, status])
  @@index([expiresAt])
}

enum NotificationChannel {
  IN_APP
  WEB_PUSH
  WHATSAPP
  EMAIL
}

enum EscalationScope {
  PLATFORM
  COMPANY
}

enum DigestStatus {
  GENERATED
  SENT
  SKIPPED
}

model NotificationPreference {
  id              String                @id @default(uuid())
  companyId       String?
  company         Company?              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId          String?
  role            String?
  type            String?
  severity        NotificationSeverity?
  channel         NotificationChannel   @default(IN_APP)
  enabled         Boolean               @default(true)
  digestEnabled   Boolean               @default(false)
  quietHoursStart String?               @db.VarChar(5)
  quietHoursEnd   String?               @db.VarChar(5)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([companyId])
  @@index([userId])
  @@index([role])
}

model NotificationEscalationRule {
  id                   String                @id @default(uuid())
  companyId            String?
  company              Company?              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  scope                EscalationScope       @default(COMPANY)
  type                 String?
  severity             NotificationSeverity?
  condition            Json?
  escalateAfterMinutes Int
  targetRole           String
  enabled              Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([companyId])
  @@index([scope])
}

model NotificationDigest {
  id          String       @id @default(uuid())
  companyId   String?
  company     Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId      String?
  role        String?
  digestDate  DateTime
  status      DigestStatus @default(GENERATED)
  summary     Json
  generatedAt DateTime     @default(now())
  createdAt   DateTime     @default(now())

  @@index([companyId])
  @@index([userId])
  @@index([role])
  @@index([digestDate])
}

// ============================================================
// Sprint 54 — Enterprise Notifications, Escalation & Human
// Follow-up Engine (event-driven target architecture).
//
// NotificationEscalationRule (above) remains the LEGACY/MAINTENANCE
// mechanism for stale in-app notification escalation. It is NOT
// unified with this engine in this sprint: the same event must never
// be processed by both mechanisms. See docs/notifications/architecture.md.
// ============================================================

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum QuietHoursBehavior {
  DEFER
  ALLOW_HIGH_PRIORITY
  IGNORE
}

enum ChannelFallbackMode {
  PARALLEL
  SEQUENTIAL
}

enum NotificationRecipientType {
  EMPLOYEE
  DIRECT_MANAGER
  HR
  ADMIN
  SPECIFIC_USER
  ROLE
  REQUESTER
  EVENT_ACTOR
}

enum NotificationWorkflowStatus {
  PENDING
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  CANCELLED
  EXHAUSTED
  FAILED
}

enum NotificationDeliveryStatus {
  SCHEDULED
  PROCESSING
  SENT
  DELIVERED
  FAILED
  SKIPPED
  SUPPRESSED
  CANCELLED
}

model NotificationPolicy {
  id                           String   @id @default(uuid())
  companyId                    String
  company                      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name                         String
  eventType                    String
  isActive                     Boolean  @default(true)
  priority                     NotificationPriority @default(NORMAL)
  acknowledgmentRequired       Boolean  @default(false)
  acknowledgmentTimeoutMinutes Int?
  maxEscalationLevel           Int      @default(1)
  quietHoursBehavior           QuietHoursBehavior @default(DEFER)
  createdById                  String?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  steps                        NotificationPolicyStep[]
  workflowInstances            NotificationWorkflowInstance[]

  @@index([companyId, eventType, isActive])
}

model NotificationPolicyStep {
  id                   String   @id @default(uuid())
  policyId             String
  policy               NotificationPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  stepOrder            Int
  delayMinutes         Int
  recipientType        NotificationRecipientType
  recipientReference   String?
  channels             Json
  fallbackMode         ChannelFallbackMode @default(PARALLEL)
  stopOnAcknowledgment Boolean  @default(true)
  stopOnResolution     Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([policyId, stepOrder])
}

model NotificationWorkflowInstance {
  id                     String   @id @default(uuid())
  companyId              String
  company                Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  policyId               String?
  policy                 NotificationPolicy? @relation(fields: [policyId], references: [id])
  eventType              String
  eventId                String
  aggregateType          String
  aggregateId            String
  priority               NotificationPriority
  status                 NotificationWorkflowStatus @default(PENDING)
  currentStep            Int      @default(0)
  nextActionAt           DateTime?
  // Snapshot of the triggering event's rendered title/message/actionUrl and
  // the audience-resolution context (e.g. employeeId, requesterUserId,
  // actorUserId). Persisted so the escalation scheduler can execute later
  // steps without needing the original in-memory call context.
  payload                Json?
  acknowledgmentRequired Boolean  @default(false)
  acknowledgedAt         DateTime?
  acknowledgedById       String?
  resolvedAt             DateTime?
  resolutionReason       String?
  deduplicationKey       String
  correlationId          String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  deliveryAttempts       NotificationDeliveryAttempt[]

  @@unique([companyId, deduplicationKey])
  @@index([status, nextActionAt])
  @@index([companyId, status, nextActionAt])
  @@index([companyId, eventType, createdAt])
}

model NotificationDeliveryAttempt {
  id                  String   @id @default(uuid())
  companyId           String
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workflowInstanceId  String
  workflowInstance    NotificationWorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)
  policyStepId        String?
  recipientUserId     String?
  recipientEmployeeId String?
  channel             String
  status              NotificationDeliveryStatus @default(SCHEDULED)
  provider            String?
  providerMessageId   String?
  idempotencyKey      String
  attemptNumber       Int      @default(1)
  scheduledAt         DateTime
  startedAt           DateTime?
  deliveredAt         DateTime?
  failedAt            DateTime?
  failureReasonCode   String?
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([companyId, idempotencyKey])
  @@index([workflowInstanceId, status])
  @@index([companyId, channel, status])
  @@index([scheduledAt])
}

model NotificationQuietHours {
  id         String   @id @default(uuid())
  companyId  String   @unique
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  timezone   String   @default("America/Sao_Paulo")
  startTime  String   @db.VarChar(5)
  endTime    String   @db.VarChar(5)
  daysOfWeek Json
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Uniqueness for (eventType, channel, version) is enforced via two
// partial unique indexes created directly in the migration SQL (Prisma's
// schema DSL cannot express a WHERE-conditional unique constraint):
//   - global templates:  WHERE "companyId" IS NULL
//   - tenant templates:  WHERE "companyId" IS NOT NULL
// See migration 20260707000000_notification_engine.
model NotificationMessageTemplate {
  id              String   @id @default(uuid())
  companyId       String?
  company         Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  eventType       String
  channel         String
  name            String
  version         Int      @default(1)
  subjectTemplate String?
  bodyTemplate    String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId, eventType, channel])
}

model TimesheetSignature {
  id              String   @id @default(uuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])
  periodMonth     String   
  signedAt        DateTime @default(now())
  signedByUserId  String
  signedByUser    User     @relation(fields: [signedByUserId], references: [id])
  ipAddress       String
  userAgent       String
  auditHash       String
  documentHash    String?
  documentVersion Int      @default(1)
  signedPayloadHash String?
  consentTextVersion String?

  @@unique([employeeId, periodMonth])
}

model PulseSurvey {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  title       String
  question    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  responses   PulseSurveyResponse[]
}

model PulseSurveyResponse {
  id            String      @id @default(uuid())
  surveyId      String
  survey        PulseSurvey @relation(fields: [surveyId], references: [id])
  employeeId    String
  employee      Employee    @relation(fields: [employeeId], references: [id])
  score         Int         
  comment       String?
  createdAt     DateTime    @default(now())

  @@unique([surveyId, employeeId])
}

model ApiKey {
  id          String    @id @default(uuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  name        String
  keyPrefix   String
  secretHash  String    // SHA-256 hash of full token — raw key is NEVER persisted
  scopes      Json
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  revokedAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model WebhookSubscription {
  id                  String   @id @default(uuid())
  companyId           String
  company             Company  @relation(fields: [companyId], references: [id])
  url                 String
  events              Json
  secretToken         String   // HMAC signing secret — shared with destination; rotatable
  isActive            Boolean  @default(true)
  deliveryLogsEnabled Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model BiometricProcessingConfiguration {
  id                         String   @id @default(uuid())
  companyId                  String   @unique
  company                    Company  @relation(fields: [companyId], references: [id])
  enabled                    Boolean  @default(false)
  purpose                    String?
  legalBasisDeclared         String?
  legalBasisNotes            String?
  retentionDays              Int      @default(30)
  alternativeMethodAvailable Boolean  @default(true)
  livenessRequired           Boolean  @default(false)
  threshold                  Float    @default(80.0)
  policyVersion              String   @default("1.0")
  activatedAt                DateTime?
  activatedByUserId          String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model WebPushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model HourBankBalance {
  id             String   @id @default(uuid())
  employeeId     String   @unique
  employee       Employee @relation(fields: [employeeId], references: [id])
  balanceMinutes Int      @default(0)
  updatedAt      DateTime @updatedAt
}

model HourBankTransaction {
  id               String   @id @default(uuid())
  employeeId       String
  employee         Employee @relation(fields: [employeeId], references: [id])
  date             DateTime
  amountMinutes    Int      // Positive for credit, negative for debit
  description      String?
  actorId          String?
  actor            User?    @relation("ActorToTransaction", fields: [actorId], references: [id])
  previousBalance  Int?
  resultingBalance Int?
  createdAt        DateTime @default(now())
}

model LeaveRequest {
  id               String        @id @default(uuid())
  companyId        String
  company          Company       @relation(fields: [companyId], references: [id])
  employeeId       String
  employee         Employee      @relation(fields: [employeeId], references: [id])
  startDate        DateTime
  endDate          DateTime
  type             String        // FERIAS, LICENCA_MEDICA, LICENCA_MATERNIDADE, etc.
  status           String        @default("PENDING") // PENDING, APPROVED, REJECTED
  justification    String?
  reviewedByUserId String?
  reviewedByUser   User?         @relation("ReviewedByToLeave", fields: [reviewedByUserId], references: [id])
  reviewedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  absenceRecord    AbsenceRecord?
}

model CalendarIntegration {
  id           String    @id @default(uuid())
  companyId    String    @unique
  company      Company   @relation(fields: [companyId], references: [id])
  provider     String    // GOOGLE, MICROSOFT
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ─── Sprint 53: Enterprise Import & Onboarding ──────────────────────────────

enum ImportJobStatus {
  UPLOADED
  PARSING
  MAPPING
  VALIDATING
  READY
  QUEUED
  IMPORTING
  COMPLETED
  PARTIAL
  FAILED
  CANCELLED
}

enum ImportMode {
  CREATE_ONLY
  UPDATE_EXISTING
  UPSERT
}

enum ImportFileType {
  CSV
  XLSX
}

enum IssueSeverity {
  ERROR
  WARNING
}

model ImportJob {
  id                String          @id @default(uuid())
  companyId         String
  company           Company         @relation(fields: [companyId], references: [id])
  createdByUserId   String
  createdByUser     User            @relation("CreatedByToImportJob", fields: [createdByUserId], references: [id])
  originalFileName  String
  fileType          ImportFileType
  selectedWorksheet String?
  status            ImportJobStatus @default(UPLOADED)
  mode              ImportMode      @default(CREATE_ONLY)
  mappings          Json?
  parsedData        Json?
  totalRows         Int             @default(0)
  processedRows     Int             @default(0)
  validRows         Int             @default(0)
  invalidRows       Int             @default(0)
  createdRows       Int             @default(0)
  updatedRows       Int             @default(0)
  skippedRows       Int             @default(0)
  failedRows        Int             @default(0)
  mappingTemplateId String?
  correlationId     String?         @unique
  startedAt         DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  issues            ImportValidationIssue[]

  @@index([companyId, status, createdAt])
}

model ImportMappingTemplate {
  id              String   @id @default(uuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  name            String
  sourceType      String   @default("CSV")
  mappings        Json
  createdByUserId String
  createdByUser   User     @relation("CreatedByToMappingTemplate", fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model ImportValidationIssue {
  id          String        @id @default(uuid())
  importJobId String
  importJob   ImportJob     @relation(fields: [importJobId], references: [id])
  rowNumber   Int
  field       String?
  code        String
  message     String
  severity    IssueSeverity @default(ERROR)
  createdAt   DateTime      @default(now())

  @@index([importJobId, severity])
}
