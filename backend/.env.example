# Server Port configuration
PORT=3001

# Environment setting (development, production, test)
NODE_ENV=development

# Database and Redis Connection details
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/presencaflow?schema=public"
REDIS_URL="redis://localhost:6379"

# Security secrets (must be at least 32 characters in production)
JWT_SECRET="super-secret-development-jwt-key-change-in-production-32-chars-long"
ENCRYPTION_SECRET="your-32-chars-long-encryption-secret-here"
INTERNAL_JOB_SECRET="dev-internal-job-secret-key-default-32-chars"

# App routing configurations
FRONTEND_URL="http://localhost:3000"
APP_BASE_URL="http://localhost:3001"

# Directory for file storage (absolute path)
STORAGE_PATH="./storage"

# Retention configurations
WHATSAPP_LOG_RETENTION_DAYS=180
AUDIT_LOG_RETENTION_DAYS=365
